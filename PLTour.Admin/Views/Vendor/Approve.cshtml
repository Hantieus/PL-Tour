@model PLTour.Shared.Models.Entities.Vendor

@{
    ViewData["Title"] = "Duyệt người bán";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.VendorId" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên cửa hàng</label>
                            <input type="text" class="form-control" value="@Model.ShopName" readonly />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chủ cửa hàng</label>
                            <input type="text" class="form-control" value="@Model.OwnerName" readonly />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input type="text" class="form-control" value="@Model.Email" readonly />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" class="form-control" value="@Model.Phone" readonly />
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    <input type="text" class="form-control" value="@Model.Address" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea class="form-control" rows="3" readonly>@Model.Description</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="Pending" selected="@(Model.Status == "Pending")">Chờ duyệt</option>
                        <option value="Approved" selected="@(Model.Status == "Approved")">Đã duyệt</option>
                        <option value="Rejected" selected="@(Model.Status == "Rejected")">Từ chối</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú (nếu từ chối)</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder="Nhập lý do từ chối...">@Model.Notes</textarea>
                </div>

                <hr />
                <div class="text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>