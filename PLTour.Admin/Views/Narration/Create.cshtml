@model PLTour.Shared.Models.Entities.Narration

@{
    ViewData["Title"] = "Thêm bài thuyết minh mới";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="LocationId" />
                <input type="hidden" asp-for="Version" value="1" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa điểm</label>
                    <input type="text" class="form-control" value="@ViewBag.Location?.Name" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="LanguageId" class="form-label fw-bold">Ngôn ngữ</label>
                    <select asp-for="LanguageId" class="form-select" asp-items="@(ViewBag.Languages as SelectList)" id="LanguageId">
                        <option value="">-- Chọn ngôn ngữ --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-bold">Nội dung</label>
                    <textarea asp-for="Content" class="form-control" rows="5" id="ContentText"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">File audio</label>
                    <input type="file" name="audioFile" class="form-control" accept="audio/*" />
                </div>

                <div class="mb-3">
                    <label asp-for="Duration" class="form-label">Thời lượng (giây)</label>
                    <input asp-for="Duration" class="form-control" type="number" min="0" />
                </div>

                <div class="form-check mb-2">
                    <input asp-for="IsDefault" class="form-check-input" />
                    <label asp-for="IsDefault" class="form-check-label">Đặt làm mặc định</label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" checked />
                    <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
                </div>

                <!-- NÚT DỊCH TỰ ĐỘNG -->
                <div class="mt-3">
                    <button type="button" id="autoTranslateBtn" class="btn btn-info">Dịch tự động</button>
                    <div id="translateResult" class="mt-2"></div>
                </div>

                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="ByLocation" asp-route-locationId="@Model.LocationId" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#autoTranslateBtn').click(function() {
                var locationId = $('#LocationId').val();
                var languageId = $('#LanguageId').val();
                var content = $('#ContentText').val();

                if (!languageId) {
                    alert('Vui lòng chọn ngôn ngữ gốc trước');
                    return;
                }

                if (!content) {
                    alert('Vui lòng nhập nội dung cần dịch');
                    return;
                }

                var btn = $(this);
                btn.prop('disabled', true).text('Đang dịch...');

                $.ajax({
                    url: '@Url.Action("AutoTranslate", "Narration")',
                    type: 'POST',
                    data: {
                        locationId: locationId,
                        sourceLanguageId: languageId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#translateResult').html('<div class="alert alert-success">' + response.message + '</div>');
                        } else {
                            $('#translateResult').html('<div class="alert alert-danger">' + response.message + '</div>');
                        }
                    },
                    error: function(xhr) {
                        $('#translateResult').html('<div class="alert alert-danger">Lỗi: ' + xhr.responseText + '</div>');
                    },
                    complete: function() {
                        btn.prop('disabled', false).text('Dịch tự động');
                    }
                });
            });
        });
    </script>
}