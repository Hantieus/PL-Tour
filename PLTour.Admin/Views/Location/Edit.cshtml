@model PLTour.Shared.Models.Entities.Location

@{
    ViewData["Title"] = "Sửa địa điểm";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@ViewData["Title"]: @Model.Name</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="LocationId" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="ImageUrl" id="existingImageUrl" />
                

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row">
                    <div class="col-md-8">
                        <!-- Giống form Create -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "Name"))">
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="OrderIndex" class="form-label fw-bold"></label>
                                    <input asp-for="OrderIndex" class="form-control" type="number" />
                                    <span asp-validation-for="OrderIndex" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Radius" class="form-label fw-bold">
                                    <i class="fas fa-ruler-combined me-1"></i>Bán kính kích hoạt (mét)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Radius" class="form-control" type="number" min="10" max="500" value="50" />
                                    <span class="input-group-text">mét</span>
                                </div>
                                <small class="text-muted">
                                    Khi người dùng vào trong bán kính này, app sẽ tự động phát thuyết minh
                                </small>
                                <span asp-validation-for="Radius" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card bg-light mb-3">
                            <div class="card-header">
                                <i class="fas fa-map-marker-alt me-1"></i>Tọa độ
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Latitude" class="form-label">Vĩ độ</label>
                                    <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Longitude" class="form-label">Kinh độ</label>
                                    <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="card bg-light mb-3">
                            <div class="card-header">
                                <i class="fas fa-image me-1"></i>Hình ảnh
                            </div>
                            <div class="card-body">
                                <!-- Hiển thị ảnh hiện tại -->
                                <div class="text-center mb-3" id="currentImageContainer">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="@Model.ImageUrl" alt="Current image" style="max-width: 100%; max-height: 150px; border-radius: 4px;" />
                                        <div class="mt-2">
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeCurrentImage()">
                                                <i class="fas fa-times me-1"></i>Xóa ảnh hiện tại
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted">Chưa có hình ảnh</p>
                                    }
                                </div>

                                <hr />
                                <label class="form-label fw-bold">Thay đổi hình ảnh</label>
                                <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewNewImage(this)" />
                                <div id="newImagePreview" class="mt-2 text-center"></div>
                            </div>
                        </div>

                        

                        <div class="form-check form-switch mb-3">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="text-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times me-1"></i>Hủy
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<script>
    function removeCurrentImage() {
        if (confirm('Bạn có chắc muốn xóa ảnh hiện tại?')) {
            document.getElementById('currentImageContainer').innerHTML = '<p class="text-muted">Đã xóa ảnh cũ</p>';
            document.getElementById('existingImageUrl').value = '';
            // Có thể thêm một hidden field để báo hiệu xóa ảnh
            $('<input>').attr({
                type: 'hidden',
                name: 'removeImage',
                value: 'true'
            }).appendTo('form');
        }
    }

    function removeCurrentAudio() {
        if (confirm('Bạn có chắc muốn xóa audio hiện tại?')) {
            document.getElementById('currentAudioContainer').innerHTML = '<p class="text-muted">Đã xóa audio cũ</p>';
            document.getElementById('existingAudioUrl').value = '';
            $('<input>').attr({
                type: 'hidden',
                name: 'removeAudio',
                value: 'true'
            }).appendTo('form');
        }
    }

    function previewNewImage(input) {
        const preview = document.getElementById('newImagePreview');
        preview.innerHTML = '';

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.maxWidth = '100%';
                img.style.maxHeight = '150px';
                img.style.borderRadius = '4px';
                preview.appendChild(img);
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>