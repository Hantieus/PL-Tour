@model IEnumerable<PLTour.Admin.Models.Entities.Narration>
@{
    var location = ViewBag.Location as PLTour.Admin.Models.Entities.Location;
    ViewData["Title"] = $"Bài thuyết minh - {location?.Name}";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3">@ViewData["Title"]</h1>
            <p class="text-muted">
                <i class="fas fa-map-marker-alt me-1"></i>@location?.Address
            </p>
        </div>
        <div>
            <a asp-action="Create" asp-route-locationId="@location?.LocationId" class="btn btn-primary">
                <i class="fas fa-plus-circle me-1"></i>Thêm bài thuyết minh
            </a>
            <a asp-controller="Location" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card @(item.IsDefault ? "border-primary" : "")">
                        <div class="card-header @(item.IsDefault ? "bg-primary text-white" : "bg-light")">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="flag-icon @item.Language?.FlagIcon me-2"></span>
                                    <strong>@item.Language?.Name</strong>
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Mặc định</span>
                                    }
                                </div>
                                <div>
                                    @if (!string.IsNullOrEmpty(item.AudioUrl))
                                    {
                                        <span class="badge bg-success me-2">
                                            <i class="fas fa-headphones me-1"></i>Audio
                                        </span>
                                    }
                                    <span class="badge bg-info">@item.Duration giây</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text text-muted" style="max-height: 100px; overflow-y: auto;">
                                @item.Content
                            </p>

                            @if (!string.IsNullOrEmpty(item.AudioUrl))
                            {
                                <audio controls class="w-100 mb-2">
                                    <source src="@item.AudioUrl" type="audio/mpeg">
                                </audio>
                            }

                            <div class="mt-2">
                                <span class="text-muted small">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    @item.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Edit" asp-route-id="@item.NarrationId" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit me-1"></i>Sửa
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.NarrationId, '@item.Language?.Name')">
                                    <i class="fas fa-trash me-1"></i>Xóa
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-4">
                    <i class="fas fa-info-circle fa-3x mb-3"></i>
                    <h5>Chưa có bài thuyết minh nào</h5>
                    <p>Thêm bài thuyết minh đầu tiên cho địa điểm này</p>
                    <a asp-action="Create" asp-route-locationId="@location?.LocationId" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-1"></i>Thêm ngay
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn xóa bài thuyết minh <strong id="deleteLanguageName"></strong>?</p>
                <p class="text-danger small">Hành động này không thể hoàn tác!</p>
            </div>
            <div class="modal-footer">
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="deleteNarrationId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, languageName) {
            document.getElementById('deleteNarrationId').value = id;
            document.getElementById('deleteLanguageName').innerText = languageName;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}