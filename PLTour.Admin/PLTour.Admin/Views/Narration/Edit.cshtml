@model PLTour.Admin.Models.Entities.Narration

@{
    ViewData["Title"] = "Sửa bài thuyết minh";
    var locationName = ViewBag.Location?.Name ?? "Không xác định";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@ViewData["Title"] - @locationName</h1>
        <a asp-action="ByLocation" asp-route-locationId="@Model.LocationId" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="NarrationId" />
                <input type="hidden" asp-for="LocationId" />
                <input type="hidden" asp-for="Version" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="AudioUrl" id="existingAudioUrl" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <strong>Vui lòng sửa các lỗi sau:</strong>
                        <ul class="mb-0 mt-2">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <!-- Tên địa điểm (chỉ hiển thị) -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Địa điểm</label>
                    <input type="text" class="form-control" value="@ViewBag.Location?.Name" readonly />
                </div>

                <!-- Ngôn ngữ (chỉ hiển thị) -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngôn ngữ</label>
                    <input type="text" class="form-control" value="@ViewBag.LanguageName" readonly />
                    <input type="hidden" asp-for="LanguageId" />
                </div>

                <!-- Tiêu đề -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- Nội dung -->
                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-bold">Nội dung thuyết minh</label>
                    <textarea asp-for="Content" class="form-control" rows="8">@Model.Content</textarea>
                </div>

                <!-- File audio hiện tại -->
                @if (!string.IsNullOrEmpty(Model.AudioUrl))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Audio hiện tại</label>
                        <div class="border p-2 rounded">
                            <audio controls class="w-100 mb-2">
                                <source src="@Model.AudioUrl" type="audio/mpeg">
                            </audio>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="removeAudio" id="removeAudio" value="true">
                                <label class="form-check-label text-danger" for="removeAudio">
                                    <i class="fas fa-trash me-1"></i>Xóa file audio này
                                </label>
                            </div>
                        </div>
                    </div>
                }

                <!-- Upload audio mới -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Thay đổi file audio</label>
                    <input type="file" name="audioFile" class="form-control" accept="audio/*" />
                    <small class="text-muted">Hỗ trợ: .mp3, .wav, .m4a (không bắt buộc)</small>
                </div>

                <!-- Thời lượng -->
                <div class="mb-3">
                    <label asp-for="Duration" class="form-label">Thời lượng (giây)</label>
                    <input asp-for="Duration" class="form-control" type="number" min="0" />
                </div>

                <!-- Tùy chọn -->
                <div class="form-check mb-2">
                    <input asp-for="IsDefault" class="form-check-input" />
                    <label asp-for="IsDefault" class="form-check-label">Đặt làm mặc định</label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
                </div>

                <!-- Nút submit -->
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Cập nhật
                </button>
                <a asp-action="ByLocation" asp-route-locationId="@Model.LocationId" class="btn btn-secondary">
                    <i class="fas fa-times me-1"></i>Hủy
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}