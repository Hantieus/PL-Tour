@model PLTour.Admin.Models.Entities.User

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-id-card me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <div class="display-1 text-primary mb-3">
                                <i class="fas fa-user-circle"></i>
                            </div>
                            <h5>@Model.FullName</h5>
                            <span class="badge bg-info">@Model.Role</span>
                        </div>
                        <div class="col-md-8">
                            <table class="table table-borderless">
                                <tr>
                                    <th style="width: 150px;">Tên đăng nhập</th>
                                    <td>@Model.Username</td>
                                </tr>
                                <tr>
                                    <th>Email</th>
                                    <td>@Model.Email</td>
                                </tr>
                                <tr>
                                    <th>Số điện thoại</th>
                                    <td>@Model.Phone</td>
                                </tr>
                                <tr>
                                    <th>Ngày tạo</th>
                                    <td>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <th>Lần đăng nhập cuối</th>
                                    <td>
                                        @if (Model.LastLoginDate.HasValue)
                                        {
                                            @Model.LastLoginDate.Value.ToString("dd/MM/yyyy HH:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa đăng nhập</span>
                                        }
                                    </td>
                                </tr>
                            </table>

                            <div class="mt-3">
                                <a asp-action="ChangePassword" class="btn btn-warning">
                                    <i class="fas fa-key me-1"></i>Đổi mật khẩu
                                </a>
                                <a asp-action="Index" asp-controller="Dashboard" class="btn btn-secondary">
                                    <i class="fas fa-home me-1"></i>Dashboard
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>