@model List<PLTour.Admin.Models.Entities.Vendor>
    @{
    ViewData["Title"] = "Dashboard";
    }

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Địa điểm</h6>
                            <h2 class="mb-0">@ViewBag.TotalLocations</h2>
                        </div>
                        <i class="fas fa-map-marker-alt fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("Index", "Location")" class="text-white text-decoration-none">
                        Xem chi tiết <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Người bán</h6>
                            <h2 class="mb-0">@ViewBag.TotalVendors</h2>
                        </div>
                        <i class="fas fa-store fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("Index", "Vendor")" class="text-white text-decoration-none">
                        Xem chi tiết <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Chờ duyệt</h6>
                            <h2 class="mb-0">@ViewBag.PendingVendors</h2>
                        </div>
                        <i class="fas fa-clock fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("Pending", "Vendor")" class="text-white text-decoration-none">
                        Xem chi tiết <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Người dùng</h6>
                            <h2 class="mb-0">@ViewBag.TotalUsers</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="@Url.Action("Index", "User")" class="text-white text-decoration-none">
                        Xem chi tiết <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Địa điểm gần đây</h5>
                </div>
                <div class="card-body">
                    <canvas id="locationsChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-clock me-2"></i>Chờ duyệt (@Model.Count)
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model != null && Model.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var vendor in Model)
                        {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">@vendor.ShopName</h6>
                                    <small class="text-muted">
                                        <i class="far fa-calendar-alt me-1"></i>
                                        @vendor.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                    @if (!string.IsNullOrEmpty(vendor.Phone))
                                        {
                                    <br />
                                    <small class="text-muted">
                                        <i class="fas fa-phone me-1"></i>@vendor.Phone
                                    </small>
                                        }
                                </div>
                                <a href="@Url.Action("Details", "Vendor", new { id = vendor.VendorId })"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="fas fa-eye"></i> Xem
                                </a>
                            </div>
                        </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-check-circle fa-3x mb-3 text-success"></i>
                        <p class="mb-0">Không có yêu cầu chờ duyệt</p>
                    </div>
                }
                </div>
                @if (Model != null && Model.Any())
            {
                <div class="card-footer text-center">
                    <a href="@Url.Action("Pending", "Vendor")" class="text-decoration-none">
                        Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            }
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
        $(document).ready(function() {
            // Biểu đồ thống kê địa điểm theo danh mục
            $.ajax({
                url: '@Url.Action("GetLocationStats", "Dashboard")',
                type: 'GET',
                success: function(data) {
                    const ctx = document.getElementById('locationsChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.labels,
                            datasets: [{
                                label: 'Số lượng địa điểm',
                                data: data.values,
                                backgroundColor: [
                                    'rgba(54, 162, 235, 0.2)',
                                    'rgba(255, 99, 132, 0.2)',
                                    'rgba(255, 206, 86, 0.2)',
                                    'rgba(75, 192, 192, 0.2)',
                                    'rgba(153, 102, 255, 0.2)'
                                ],
                                borderColor: [
                                    'rgba(54, 162, 235, 1)',
                                    'rgba(255, 99, 132, 1)',
                                    'rgba(255, 206, 86, 1)',
                                    'rgba(75, 192, 192, 1)',
                                    'rgba(153, 102, 255, 1)'
                                ],
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    stepSize: 1
                                }
                            }
                        }
                    });
                }
            });
        });
        </script>
    }
