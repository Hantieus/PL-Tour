<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:PLTour.App.Controls"
             x:Class="PLTour.App.Pages.MapPage"
             Title="Map"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F3F6F9">

    <Grid x:Name="MainGrid" RowDefinitions="Auto,*,380">

        <!-- Audio player dùng cho thuyết minh -->
        <toolkit:MediaElement x:Name="AudioPlayer"
                              ShouldAutoPlay="False"
                              IsVisible="False"
                              MediaEnded="AudioPlayer_MediaEnded" />

        <!-- Thanh trên cùng -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                Padding="14,12"
                StrokeThickness="0"
                ZIndex="5">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" RowSpacing="4">
                <Button Text="🔙"
        WidthRequest="44"
        HeightRequest="44"
        CornerRadius="22"
        BackgroundColor="#F1F3F5"
        TextColor="#111827"
        FontAttributes="Bold"
        Clicked="Back_Clicked" />

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="#F8FAFC"
                        Padding="12,0"
                        HeightRequest="44">
                    <Entry x:Name="txtSearch"
                           Placeholder="Tìm kiếm địa điểm..."
                           BackgroundColor="Transparent"
                           ClearButtonVisibility="WhileEditing"
                           TextColor="#111827"
                           PlaceholderColor="#94A3B8"
                           VerticalOptions="Center" />
                </Border>

                <Button Grid.RowSpan="2"
                        Grid.Column="2"
                        Text="🔍"
                        BackgroundColor="#EAF2F2"
                        TextColor="#2A9D8F"
                        FontAttributes="Bold"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="22"
                        Clicked="VoiceSearch_Clicked" />
            </Grid>
        </Border>

        <!-- Khu vực bản đồ -->
        <Grid x:Name="MapSection"
              Grid.Row="1"
              ZIndex="1">
            <Border StrokeThickness="0"
                    BackgroundColor="#EAF0F4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>
                <Grid x:Name="MapContainer" />
            </Border>

            <VerticalStackLayout HorizontalOptions="Start"
                                 VerticalOptions="End"
                                 Margin="16,0,0,22"
                                 Spacing="10"
                                 ZIndex="10">
                <Button x:Name="BtnToggleMap"
                        Text="Mở rộng"
                        WidthRequest="104"
                        HeightRequest="42"
                        CornerRadius="21"
                        BackgroundColor="White"
                        TextColor="#2A9D8F"
                        FontAttributes="Bold"
                        Clicked="ToggleMapSize_Clicked">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.18" Offset="0,2" Radius="4" />
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>

            <Button Text="🎯" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,35,25"
                    WidthRequest="60" HeightRequest="60" CornerRadius="30" BackgroundColor="White" TextColor="#2A9D8F" 
                    FontSize="24" Clicked="CurrentLocation_Clicked" ZIndex="10">
                <Button.Shadow>
                    <Shadow Brush="Black" Opacity="0.4" Offset="0,4" Radius="8"/>
                </Button.Shadow>
            </Button>
            
        </Grid>

        <!-- Danh sách địa điểm -->
        <Border x:Name="InfoPanel"
                Grid.Row="2"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 25,25,0,0"
                BackgroundColor="#F8FAFC"
                ZIndex="2">
            <Grid RowDefinitions="Auto,*" Padding="16,16,16,12">
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding TourHeaderText}"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="#111827"
                               VerticalOptions="Center" />
                        <Label Text="Chọn tab để lọc"
                               FontSize="12"
                               TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Grid>

                <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout Spacing="14">
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout x:Name="CategoryTabsContainer" Spacing="8" />
                        </ScrollView>

                        <CollectionView x:Name="PoiListView"
                                        SelectionMode="None"
                                        EmptyView="Chưa có địa điểm phù hợp">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            StrokeShape="RoundRectangle 18"
                                            StrokeThickness="0"
                                            BackgroundColor="White">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.06" />
                                        </Border.Shadow>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="PoiItem_Tapped" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <VerticalStackLayout Spacing="10">
                                            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" HeightRequest="120">
                                                <Image Source="{Binding ImageUrl}"
                                                       HeightRequest="120"
                                                       Aspect="AspectFill" />
                                            </Border>

                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontAttributes="Bold"
                                                       FontSize="16"
                                                       TextColor="#111827"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Address}"
                                                       FontAttributes="Bold"
                                                       FontSize="13"
                                                       TextColor="#E76F51"
                                                       VerticalOptions="Center" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                                                <Button Grid.Column="0"
                                                        Text="📍 Bản đồ"
                                                        Clicked="BtnViewMap_Clicked"
                                                        CommandParameter="{Binding .}"
                                                        HeightRequest="36"
                                                        BackgroundColor="#EAF2F2"
                                                        TextColor="#111827"
                                                        FontSize="12"
                                                        Padding="0" />
                                                <Button Grid.Column="1"
                                                        Text="{Binding PlayButtonText}"
                                                        BackgroundColor="{Binding PlayButtonColor}"
                                                        Clicked="BtnSpeak_Clicked"
                                                        CommandParameter="{Binding .}"
                                                        HeightRequest="36"
                                                        TextColor="#111827"
                                                        FontSize="12"
                                                        Padding="0" />
                                                <Button Grid.Column="2"
                                                        Text="🧭 Đi"
                                                        Clicked="BtnRoute_Clicked"
                                                        CommandParameter="{Binding .}"
                                                        HeightRequest="36"
                                                        BackgroundColor="#2A9D8F"
                                                        TextColor="White"
                                                        FontSize="12"
                                                        Padding="0" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

        <!-- Popup chi tiết -->
        <controls:PoiDetailPopup x:Name="PoiDetailPopup"
                                 IsVisible="False"
                                 SpeakButtonClicked="PoiDetailPopup_SpeakButtonClicked"
                                 ViewMapButtonClicked="PoiDetailPopup_ViewMapButtonClicked" />
    </Grid>
</ContentPage>