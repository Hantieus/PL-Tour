<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PLTour.App.Pages.PoiDetailPopupView"
             BackgroundColor="#99000000">

    <Border BackgroundColor="White" 
            StrokeShape="RoundRectangle 20" 
            HorizontalOptions="Center" 
            VerticalOptions="Center" 
            WidthRequest="350" 
            MaximumHeightRequest="650" 
            Padding="0" 
            Margin="20">

        <Grid RowDefinitions="Auto, *, Auto">
            <Grid Grid.Row="0">
                <Image Source="{Binding ImageUrl}" 
                       HeightRequest="200" 
                       Aspect="AspectFill" />
                <Button Text="❌" 
                        BackgroundColor="#80000000" 
                        TextColor="White" 
                        CornerRadius="15" 
                        WidthRequest="30" 
                        HeightRequest="30" 
                        HorizontalOptions="End" 
                        VerticalOptions="Start" 
                        Margin="10" 
                        Padding="0" 
                        Clicked="ClosePopup_Clicked" />
            </Grid>

            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="22" TextColor="Black" />
                    <Label Text="{Binding Address}" FontSize="14" TextColor="#E76F51" FontAttributes="Italic" />

                    <Label Text="📌 Mô tả ngắn:" FontAttributes="Bold" FontSize="15" TextColor="#2A9D8F" Margin="0,10,0,0"/>
                    <Label Text="{Binding Description}" FontSize="14" TextColor="DarkGray" />

                    <Label Text="📖 Nội dung chi tiết:" FontAttributes="Bold" FontSize="15" TextColor="#2A9D8F" Margin="0,10,0,0"/>
                    <Label Text="{Binding FullContent}" FontSize="14" TextColor="Black" />

                    <VerticalStackLayout IsVisible="{Binding IsDiningCategory}" 
                                         Margin="0,15,0,0" 
                                         Spacing="5" 
                                         BackgroundColor="#FFF3E0" 
                                         Padding="15">
                        <Label Text="🍽️ Thực đơn (Menu):" FontAttributes="Bold" FontSize="16" TextColor="#D84315" />

                        <ActivityIndicator IsRunning="{Binding IsLoadingMenu}" 
                                           IsVisible="{Binding IsLoadingMenu}" 
                                           Color="#D84315" 
                                           HorizontalOptions="Center"/>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding MenuItems}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="10" Margin="0,3">
                                        <Label Text="•" TextColor="#D84315" FontAttributes="Bold"/>
                                        <Label Text="{Binding Name}" FontSize="14" TextColor="Black" FontAttributes="Bold" />
                                        <Label Text="{Binding Price, StringFormat='- {0:N0}đ'}" FontSize="14" TextColor="#D84315" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="2" 
                    Text="{Binding PlayButtonText}" 
                    BackgroundColor="{Binding PlayButtonColor}" 
                    Clicked="BtnSpeak_Clicked" 
                    HeightRequest="50" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    FontSize="15" 
                    Margin="20,10,20,20" 
                    CornerRadius="10" />
        </Grid>
    </Border>
</ContentView>