<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PLTour.App.Pages.SettingsPage"
             Title="Cài đặt">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="Tài khoản" FontAttributes="Bold"/>
        <Button Text="👤 Quản lý tài khoản" BackgroundColor="LightGray" TextColor="Black"/>

        <Label Text="Giao diện" FontAttributes="Bold"/>
        <HorizontalStackLayout Spacing="10">
            <Label Text="Chế độ tối (Dark Mode)" VerticalOptions="Center"/>
            <Switch x:Name="ThemeSwitch" Toggled="ThemeSwitch_Toggled"/>
        </HorizontalStackLayout>

        <Label Text="Ngôn ngữ &amp; Thuyết minh" FontAttributes="Bold"/>
        <Picker x:Name="LangPicker" Title="Chọn ngôn ngữ">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>Tiếng Việt</x:String>
                    <x:String>English</x:String>
                </x:Array>
            </Picker.ItemsSource>
        </Picker>
    </VerticalStackLayout>
</ContentPage>