<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:PLTour.App.Controls"
             xmlns:models="clr-namespace:PLTour.App.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PLTour.App.Pages.TourDetailPage"
             Title="Chi tiết Tour"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                Margin="16,16,16,8"
                Padding="16"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.14" Offset="0,6" Radius="16" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Button Text="🔙"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            BackgroundColor="#F1F3F5"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            Clicked="Back_Clicked" />

                    <Label x:Name="lblTourName"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1F2937" />

                    <Button Grid.Column="2"
                            Text="Xem bản đồ"
                            Padding="16,0"
                            HeightRequest="44"
                            CornerRadius="22"
                            BackgroundColor="#2A9D8F"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="ViewMap_Clicked" />
                </Grid>

                <Border Grid.Row="1"
                        HeightRequest="220"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.12" Offset="0,4" Radius="12" />
                    </Border.Shadow>
                    <Image x:Name="imgTour"
                           Source="{Binding ImageUrl}"
                           Aspect="AspectFill"
                           BackgroundColor="#EEF2F7" />
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="*" ColumnSpacing="12">
                    <Button Text="Nghe giới thiệu"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="#E9ECEF"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            Clicked="SpeakIntro_Clicked" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,8,16,16"
                Padding="16"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.10" Offset="0,6" Radius="16" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button x:Name="BtnTouristSpots"
                            Text="Tham quan"
                            HeightRequest="42"
                            CornerRadius="21"
                            BackgroundColor="#2A9D8F"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="FilterTouristSpots_Clicked" />
                    <Button x:Name="BtnFoodPlaces"
                            Grid.Column="1"
                            Text="Ăn uống"
                            HeightRequest="42"
                            CornerRadius="21"
                            BackgroundColor="#E9ECEF"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            Clicked="FilterFoodPlaces_Clicked" />
                    <Button x:Name="BtnEvents"
                            Grid.Column="2"
                            Text="Sự kiện"
                            HeightRequest="42"
                            CornerRadius="21"
                            BackgroundColor="#E9ECEF"
                            TextColor="#111827"
                            FontAttributes="Bold"
                            Clicked="FilterEvents_Clicked" />
                </Grid>

                <Label Grid.Row="1"
                       Text="Các địa điểm trong Tour"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#6B7280" />

                <CollectionView Grid.Row="2"
                                x:Name="PoiList"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PoiModel">
                            <Border Margin="0,0,0,12"
                                    Padding="14"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.10" Offset="0,4" Radius="10" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="PoiItem_Tapped" />
                                </Border.GestureRecognizers>

                                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            HeightRequest="130">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               BackgroundColor="#EEF2F7" />
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1" Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Address}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#E76F51"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <Label Text="{Binding Category}"
                                               FontSize="11"
                                               TextColor="#2A9D8F"
                                               FontAttributes="Italic" />

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Button Text="{Binding PlayButtonText}"
                                                    BackgroundColor="{Binding PlayButtonColor}"
                                                    HeightRequest="36"
                                                    CornerRadius="10"
                                                    FontSize="11"
                                                    TextColor="#111827"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="BtnSpeakPoi_Clicked" />
                                            <Button Grid.Column="1"
                                                    Text="🧭 Đi"
                                                    HeightRequest="36"
                                                    CornerRadius="10"
                                                    BackgroundColor="#007BFF"
                                                    TextColor="White"
                                                    FontSize="11"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="BtnRoute_Clicked" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <controls:PoiDetailPopup x:Name="PoiDetailPopup"
                                 Grid.RowSpan="2"
                                 IsVisible="False"
                                 ZIndex="100"
                                 CloseRequested="PoiDetailPopup_CloseRequested"
                                 SpeakRequested="PoiDetailPopup_SpeakRequested"
                                 ViewMapRequested="PoiDetailPopup_ViewMapRequested" />

        <toolkit:MediaElement x:Name="AudioPlayer"
                              Grid.RowSpan="2"
                              IsVisible="False"
                              MediaEnded="AudioPlayer_MediaEnded" />
    </Grid>
</ContentPage>
