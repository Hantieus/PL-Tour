<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PLTour.App.MainPage">

    <Grid RowDefinitions="*, 350">

        <Grid x:Name="MainGrid" Grid.Row="0">
            <Border x:Name="LoadingOverlay" Margin="10,40,10,0" Padding="15,5" HorizontalOptions="Center" VerticalOptions="Start"
                    StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="#CC000000" ZIndex="10">
                <VerticalStackLayout Spacing="0">
                    <Label x:Name="lblInfo" Text="Đang tìm vị trí của bạn..." TextColor="White" FontSize="12" HorizontalTextAlignment="Center" />
                    <Picker x:Name="LanguagePicker" Title="Đang tải giọng đọc..." TextColor="LightSkyBlue" TitleColor="LightGray" 
                            FontSize="12" HorizontalTextAlignment="Center" SelectedIndexChanged="LanguagePicker_SelectedIndexChanged" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="1" StrokeThickness="0" StrokeShape="RoundRectangle 25,25,0,0" BackgroundColor="#F8F9FA">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="15" Opacity="0.1" />
            </Border.Shadow>

            <VerticalStackLayout Padding="15">

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,0,0,15">
                    <Button x:Name="TabThamQuan" Grid.Column="0" Text="Tham quan" FontAttributes="Bold" CornerRadius="10" 
                            BackgroundColor="#2A9D8F" TextColor="White" Clicked="Tab_Clicked" CommandParameter="Tham quan" />
                    <Button x:Name="TabAnUong" Grid.Column="1" Text="Ăn uống" FontAttributes="Bold" CornerRadius="10" 
                            BackgroundColor="#D3D3D3" TextColor="DimGray" Clicked="Tab_Clicked" CommandParameter="Ăn uống" />
                    <Button x:Name="TabSuKien" Grid.Column="2" Text="Sự kiện" FontAttributes="Bold" CornerRadius="10" 
                            BackgroundColor="#D3D3D3" TextColor="DimGray" Clicked="Tab_Clicked" CommandParameter="Giải trí / Sự kiện" />
                </Grid>

                <CollectionView x:Name="PoiListView" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,15" Padding="15" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="White">
                                <Border.Shadow>
                                    <Shadow Brush="Gray" Offset="0,2" Radius="5" Opacity="0.2"/>
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="5">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#222222" />
                                        <Label Grid.Column="1" Text="{Binding DistanceText}" FontAttributes="Italic" FontSize="14" TextColor="Red" />
                                    </Grid>

                                    <Label Text="{Binding Description}" FontSize="13" TextColor="Gray" Margin="0,0,0,10"/>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Text="📍 Xem Map" FontSize="11" CornerRadius="8" Padding="0" HeightRequest="35"
                                                BackgroundColor="#E9ECEF" TextColor="Black" CommandParameter="{Binding .}" Clicked="BtnViewMap_Clicked" />
                                        <Button Grid.Column="1" Text="🔊 Nghe" FontSize="11" CornerRadius="8" Padding="0" HeightRequest="35"
                                                BackgroundColor="#E9ECEF" TextColor="Black" CommandParameter="{Binding .}" Clicked="BtnSpeak_Clicked" />
                                        <Button Grid.Column="2" Text="🧭 Chỉ đường" FontSize="11" CornerRadius="8" Padding="0" HeightRequest="35"
                                                BackgroundColor="#007BFF" TextColor="White" CommandParameter="{Binding .}" Clicked="BtnRoute_Clicked" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>