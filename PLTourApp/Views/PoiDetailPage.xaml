<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PLTourApp.Views.PoiDetailPage">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="10">

            <Image
                x:Name="PoiImage"
                HeightRequest="200"
                Aspect="AspectFill"/>

            <Label
                x:Name="PoiName"
                FontSize="24"
                FontAttributes="Bold"/>

            <Label
                x:Name="PoiDescription"
                FontSize="16"/>

            <Button
                Text="Nghe thuyết minh"
                Clicked="PlayAudio"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>