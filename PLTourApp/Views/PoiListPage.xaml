<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PLTourApp.Views.PoiListPage">

    <CollectionView
        x:Name="PoiList">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Frame Margin="10">

                    <VerticalStackLayout>

                        <Label
                            Text="{Binding Name}"
                            FontSize="18"
                            FontAttributes="Bold"/>

                        <Label
                            Text="{Binding Description}"
                            FontSize="14"/>

                    </VerticalStackLayout>

                </Frame>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>