<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="PLTourApp.Views.MapPage">

	<Grid>

		<maps:Map
            x:Name="TourMap"
            IsShowingUser="True"
            MapType="Street"/>

		<Frame
            BackgroundColor="White"
            Padding="10"
            VerticalOptions="End"
            Margin="20"
            HasShadow="True">

			<VerticalStackLayout Spacing="5">

				<Label
                    Text="Điểm gần nhất"
                    FontAttributes="Bold"
                    FontSize="18"/>

				<Label
                    x:Name="NearestPoiLabel"
                    FontSize="16"
                    Text="Chưa xác định"/>

			</VerticalStackLayout>

		</Frame>

	</Grid>

</ContentPage>