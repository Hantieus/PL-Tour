<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PLTourApp.Views"
    x:Class="PLTourApp.AppShell">

    <TabBar>
        <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Title="Map"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="PoI"
            ContentTemplate="{DataTemplate views:PoiListPage}" />

        <ShellContent
            Title="QR"
            ContentTemplate="{DataTemplate views:QRScannerPage}" />

        <ShellContent
            Title="Analytics"
            ContentTemplate="{DataTemplate views:AnalyticsPage}" />

    </TabBar>

</Shell>