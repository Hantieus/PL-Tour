@model PLTour.Shared.Models.Entities.Vendor
@{
    ViewData["Title"] = "Dashboard - Quản lý cửa hàng";
    Layout = "_VendorLayout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Chào mừng, @Model.ShopName!</h1>
        <span class="badge bg-success fs-6">
            <i class="fas fa-check-circle me-1"></i>Đã duyệt
        </span>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Món ăn</h6>
                            <h2 class="mb-0">@ViewBag.ProductCount</h2>
                        </div>
                        <i class="fas fa-utensils fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/vendor/products" class="text-white text-decoration-none">
                        Quản lý món ăn <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Hình ảnh</h6>
                            <h2 class="mb-0">@ViewBag.ImageCount</h2>
                        </div>
                        <i class="fas fa-images fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="/vendor/gallery" class="text-white text-decoration-none">
                        Thư viện ảnh <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Lượt xem</h6>
                            <h2 class="mb-0">0</h2>
                        </div>
                        <i class="fas fa-eye fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông tin cửa hàng -->
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-store me-2"></i>Logo cửa hàng</h5>
                </div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                    <img src="@Model.LogoUrl" alt="@Model.ShopName" class="img-fluid rounded" style="max-height: 150px;" />
                    }
                    else
                    {
                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 150px; border-radius: 8px;">
                        <i class="fas fa-store fa-3x"></i>
                    </div>
                    }
                    <div class="mt-3">
                        <a href="/vendor/profile" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-edit me-1"></i>Cập nhật logo
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin cửa hàng</h5>
                    <a href="/vendor/profile" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit me-1"></i>Sửa
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 150px;">Tên cửa hàng</th>
                            <td>@Model.ShopName</td>
                        </tr>
                        <tr>
                            <th>Chủ cửa hàng</th>
                            <td>@Model.OwnerName</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th>Số điện thoại</th>
                            <td>@Model.Phone</td>
                        </tr>
                        <tr>
                            <th>Địa chỉ</th>
                            <td>@Model.Address</td>
                        </tr>
                        <tr>
                            <th>Mô tả</th>
                            <td>@Model.Description</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>