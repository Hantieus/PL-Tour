@using PLTour.Shared.Models.Entities
@model IEnumerable<VendorImage>
    @{
    ViewData["Title"] = "Thư viện ảnh";
    Layout = "_VendorLayout";
    }

    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3">@ViewData["Title"]</h1>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addImageModal">
                <i class="fas fa-plus-circle me-1"></i>Thêm ảnh
            </button>
        </div>

        @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

        @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
            <div class="col-md-3 mb-3">
                <div class="card">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;" />
                    <div class="card-body p-2">
                        <p class="card-text small mb-1">@item.Title</p>
                        <span class="badge bg-secondary">@item.ImageType</span>
                    </div>
                    <div class="card-footer p-2">
                        <div class="btn-group w-100">
                            <button type="button" class="btn btn-sm btn-outline-success" onclick="setAsLogo(@item.ImageId)">
                                <i class="fas fa-image"></i> Logo
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteImage(@item.ImageId)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-images fa-4x text-muted mb-3"></i>
            <h5 class="text-muted">Chưa có ảnh nào</h5>
            <p>Hãy thêm ảnh về quán, món ăn, không gian để thu hút khách hàng</p>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addImageModal">
                <i class="fas fa-plus-circle me-1"></i>Thêm ảnh đầu tiên
            </button>
        </div>
    }
    </div>

    <!-- Modal thêm ảnh -->
    <div class="modal fade" id="addImageModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Thêm ảnh mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="AddImage" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn ảnh</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tiêu đề</label>
                            <input type="text" name="title" class="form-control" placeholder="Ví dụ: Mặt tiền quán, Món phở đặc trưng..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Loại ảnh</label>
                            <select name="imageType" class="form-select">
                                <option value="restaurant">Không gian quán</option>
                                <option value="dish">Món ăn</option>
                                <option value="menu">Menu</option>
                                <option value="logo">Logo</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary">Tải lên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <form id="setLogoForm" asp-action="SetAsLogo" method="post" style="display:none;">
        <input type="hidden" name="id" id="logoId" />
    </form>
    <form id="deleteImageForm" asp-action="DeleteImage" method="post" style="display:none;">
        <input type="hidden" name="id" id="deleteImageId" />
    </form>

    @section Scripts {
        <script>
        function setAsLogo(id) {
            if (confirm('Đặt ảnh này làm logo cửa hàng?')) {
                document.getElementById('logoId').value = id;
                document.getElementById('setLogoForm').submit();
            }
        }

        function deleteImage(id) {
            if (confirm('Bạn có chắc muốn xóa ảnh này?')) {
                document.getElementById('deleteImageId').value = id;
                document.getElementById('deleteImageForm').submit();
            }
        }
        </script>
    }
